@startuml
!theme plain
title Data-Processor Package Structure

package at.mafue.baumradar.dataprocessor {
  
  class Main {
    - {static} BASE_URL: String
    - {static} PUB_KEY_FILE: String
    + {static} main(String[] args)
  }

  package models {
    class TreeRecord {
      + id: String
      + cityId: String
      + latitude: double
      + longitude: double
      + genusDe: String
      + genusEn: String
      + speciesDe: String
      + speciesEn: String
    }
    class GeofenceRecord {
      + id: String
      + cityId: String
      + latitude: double
      + longitude: double
      + radius: int
      + count: int
      + genusDe: String
    }
  }

  package providers {
    interface CityProvider {
      + getCityId(): String
      + getName(): String
      + getCountry(): String
      + getBoundingBox(): double[]
      + processData(DatabaseExporter exporter)
    }
    abstract class AbstractGeoJsonProvider implements CityProvider {
      # isZipped(): boolean
      # supportsPagination(): boolean
      # getGeoJsonUrl(offset: int): String
      # mapFeatureToTree(feature: JsonNode): TreeRecord
    }
    abstract class AbstractCsvProvider implements CityProvider {
      # getCsvUrl(): String
      # getSplitRegex(): String
      # processHeaders(headers: String[])
      # mapRowToTree(row: String[], lineNumber: long): TreeRecord
    }

    package austria {
      class ViennaProvider extends AbstractCsvProvider
      class LinzProvider extends AbstractCsvProvider
    }
    
    package germany {
      class BerlinProvider extends AbstractGeoJsonProvider
      class HamburgProvider extends AbstractGeoJsonProvider
      class FreiburgProvider extends AbstractGeoJsonProvider
      class DortmundProvider extends AbstractGeoJsonProvider
    }
    
    package switzerland {
      class ZurichProvider extends AbstractGeoJsonProvider
      class BaselProvider extends AbstractGeoJsonProvider
    }
  }

  package utils {
    class DatabaseExporter {
      + open()
      + createTable()
      + insertBatch(trees: List<TreeRecord>)
      + insertGeofences(geofences: List<GeofenceRecord>)
      + close()
    }
    class CatalogBuilder {
      + {static} build(outputFile: File, providers: List<CityProvider>, baseUrl: String)
    }
    class CryptoManager {
      + loadOrGenerateKeyPair(privFile: File, pubFile: File)
      + savePublicKey(file: File)
      + signFile(dataFile: File, signatureFile: File)
    }
    class Translator {
      + {static} translateGenus(german: String): String
      + {static} translateSpecies(german: String): String
    }
    class UtmConverter {
      + {static} utm32NToWgs84(easting: double, northing: double): double[]
    }
  }
}

Main --> CityProvider : iterates (parallel via ExecutorService)
Main --> DatabaseExporter : creates per city
Main --> CryptoManager : loadOrGenerateKeyPair + signFile
Main --> CatalogBuilder : builds catalog.json
AbstractGeoJsonProvider ..> TreeRecord : creates
AbstractCsvProvider ..> TreeRecord : creates
AbstractGeoJsonProvider ..> UtmConverter : uses (optional, e.g. Hamburg)
AbstractCsvProvider ..> Translator : translates genus/species
AbstractGeoJsonProvider ..> Translator : translates genus/species
@enduml
